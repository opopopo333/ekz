<Page x:Class="IKZAMEN1.MoviesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:IKZAMEN1"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MoviesPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <TextBox x:Name="tbSearch" Width="200" Margin="0,0,10,0" 
             TextChanged="tbSearch_TextChanged" 
             VerticalContentAlignment="Center"/>
            <Button Content="↑ Цена" Click="BtnSortAsc_Click" Margin="0,0,5,0"/>
            <Button Content="↓ Цена" Click="BtnSortDesc_Click"/>
        </StackPanel>

        <DataGrid x:Name="dgMovies" Grid.Row="1" AutoGenerateColumns="False"
          IsReadOnly="True" SelectionMode="Single" Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Жанр" Binding="{Binding Genre}" Width="100"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
        <Button Content="Выбрать фильм" Grid.Row="2" VerticalAlignment="Bottom" 
        Margin="10" Click="BtnSelect_Click"/>
    </Grid>
</Page>
